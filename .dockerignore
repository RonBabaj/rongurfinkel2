# Keep the Docker build context clean so host node_modules/.next
# cannot overwrite the image's `npm ci` install (causes Next/SWC skew).
.git
.github
.gitignore
.dockerignore

node_modules
.next
out
dist
build
coverage
.turbo
.cache

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.env
.env.*
!.env.example

README.md
docs
deploy
*.md
.DS_Store
